#!/usr/bin/env xonsh

from rich.console import Console
console = Console()

version = "37"

iso_path = pf"/var/lib/mock/viperos-{version}-x86_64/root/var/lmc"
config_path = pf"/var/lib/mock/viperos-{version}-x86_64/root/builddir/custom-config"

console.rule(f"[bold cyan]Extracting ISO and post process...", style="cyan")

sudo setenforce 0

sudo mv @(iso_path)/*.iso $HOME

# Delete the iso directory
sudo rm -rf @(iso_path)

# Delete the config directory
sudo rm -rf @(config_path)

sudo setenforce 1

console.print("Done", style="cyan")
