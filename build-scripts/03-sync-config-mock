#!/usr/bin/env xonsh

from rich.console import Console
console = Console()

from viperos_globals import source_path, destination_path

console.rule(f"[bold cyan]Synchronizing config files to {destination_path}...", style="cyan")

sudo setenforce 0

# Delete the destination
sudo rm -rf @(destination_path)

# Create the destination path
sudo mkdir -p @(destination_path)

# BTRFS copy the files
sudo cp -rv --reflink=auto @(source_path) @(destination_path)

sudo setenforce 1

console.print("Done", style="cyan")
