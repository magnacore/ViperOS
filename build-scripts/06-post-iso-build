#!/usr/bin/env xonsh

from rich.console import Console
console = Console()

from viperos_globals import destination_path, iso_path

console.rule(f"[bold cyan]Extracting ISO and post process...", style="cyan")

sudo setenforce 0

sudo mv @(iso_path)/*.iso $HOME

# Delete the iso directory
sudo rm -rf @(iso_path)

# Delete the config directory
sudo rm -rf @(destination_path)

sudo setenforce 1

console.print("Done", style="cyan")
